---
---

<section id="about" class="relative min-h-screen flex items-center justify-center px-6 pt-20">
  <div class="max-w-4xl mx-auto text-center">
    <div class="mb-8 inline-block">
      <span class="px-4 py-2 text-xs font-mono text-tech-blue border border-tech-blue/30 rounded-full bg-tech-blue/5">
        AI 算法负责人 · 智能建造
      </span>
    </div>

    <h1 class="text-5xl md:text-7xl font-bold mb-6 tracking-tight">
      <span class="text-white">张</span>
      <span class="text-tech-blue">子</span>
      <span class="text-white">睿</span>
    </h1>

    <p class="text-xl md:text-2xl text-gray-400 mb-8 font-light leading-relaxed">
      探索 AI 与建筑的融合边界
    </p>

    <div class="flex flex-wrap justify-center gap-4 mb-12">
      <a
        href="#experience"
        class="px-8 py-3 bg-gradient-to-r from-tech-blue to-tech-purple text-white font-medium rounded-lg hover:opacity-90 transition-opacity"
      >
        查看经历
      </a>
      <a
        href="#contact"
        class="px-8 py-3 border border-tech-blue/50 text-tech-blue font-medium rounded-lg hover:bg-tech-blue/10 transition-colors"
      >
        联系我
      </a>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-2xl mx-auto">
      <div class="text-center p-4 rounded-lg bg-white/5 backdrop-blur-sm border border-white/10">
        <div class="text-3xl font-bold text-tech-blue mb-1">5+</div>
        <div class="text-xs text-gray-500">年经验</div>
      </div>
      <div class="text-center p-4 rounded-lg bg-white/5 backdrop-blur-sm border border-white/10">
        <div class="text-3xl font-bold text-tech-purple mb-1">5项</div>
        <div class="text-xs text-gray-500">专利</div>
      </div>
      <div class="text-center p-4 rounded-lg bg-white/5 backdrop-blur-sm border border-white/10">
        <div class="text-3xl font-bold text-tech-cyan mb-1">1篇</div>
        <div class="text-xs text-gray-500">核心论文</div>
      </div>
      <div class="text-center p-4 rounded-lg bg-white/5 backdrop-blur-sm border border-white/10">
        <div class="text-3xl font-bold text-tech-blue mb-1">3+</div>
        <div class="text-xs text-gray-500">奖学金</div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-tech-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
