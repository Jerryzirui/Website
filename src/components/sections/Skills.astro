---
const skillGroups = [
  {
    category: '编程语言',
    skills: ['Python', 'JavaScript/TypeScript', 'C++/C#'],
  },
  {
    category: 'AI & 算法',
    skills: ['RAG', '多智能体', '运动规划', '点云处理 (Open3D, PCL)'],
  },
  {
    category: '技术框架',
    skills: ['Vue.js', 'Node.js', 'FastAPI', 'LangChain', 'ROS'],
  },
  {
    category: '专业工具',
    skills: ['Rhino/Grasshopper', 'Revit', 'COMSOL', 'MATLAB', 'AutoCAD', 'Docker', 'Git'],
  },
];

const languages = [
  { name: 'CET-6', level: 520 },
  { name: 'IELTS', level: 7.0 },
  { name: 'Duolingo', level: 115 },
];

const awards = [
  '美国大学生数学建模竞赛 Meritorious Winner',
  '全国大学生结构信息大赛 国家二等奖',
  '全国大学生数学建模竞赛 二等奖',
];
---

<section id="skills" class="relative py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold mb-12 text-center">
      <span class="text-tech-blue">//</span> 技能树
    </h2>

    <div class="grid md:grid-cols-2 gap-6 mb-12">
      {skillGroups.map((group, index) => (
        <div
          class="p-6 rounded-lg bg-white/5 backdrop-blur-sm border border-white/10 hover:border-tech-blue/30 transition-colors"
          style={`animation-delay: ${index * 0.1}s`}
        >
          <h3 class="text-sm font-mono text-tech-purple mb-4">{group.category}</h3>
          <div class="flex flex-wrap gap-2">
            {group.skills.map((skill) => (
              <span class="px-3 py-1.5 text-sm rounded bg-tech-blue/10 text-tech-blue border border-tech-blue/30 hover:bg-tech-blue/20 transition-colors">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="p-6 rounded-lg bg-white/5 backdrop-blur-sm border border-white/10 mb-8">
      <h3 class="text-sm font-mono text-tech-purple mb-4">语言能力</h3>
      <div class="space-y-4">
        {languages.map((lang) => (
          <div class="flex items-center gap-4">
            <span class="text-sm text-gray-400 w-20">{lang.name}</span>
            <div class="flex-1 h-2 bg-white/10 rounded-full overflow-hidden">
              <div
                class="h-full bg-gradient-to-r from-tech-blue to-tech-purple rounded-full"
                style={`width: ${Math.min((lang.level / 10) * 100, 100)}%`}
              ></div>
            </div>
            <span class="text-xs font-mono text-tech-cyan w-12">{lang.level}</span>
          </div>
        ))}
      </div>
      <p class="mt-4 text-sm text-gray-500">普通话、粤语（母语）</p>
    </div>

    <div class="p-6 rounded-lg bg-gradient-to-r from-tech-purple/10 to-tech-blue/10 border border-tech-purple/20">
      <h3 class="text-sm font-mono text-tech-purple mb-4">荣誉奖项</h3>
      <ul class="space-y-2">
        {awards.map((award) => (
          <li class="flex items-center gap-3 text-sm text-gray-300">
            <span class="w-2 h-2 rounded-full bg-tech-blue"></span>
            {award}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
