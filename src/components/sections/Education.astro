---
const education = [
  {
    period: '2022.10 — 2024.12',
    school: '以色列海法大学',
    degree: 'Thesis-base 硕士',
    major: '海洋计算科学',
    grade: 'GRADE: 90.5',
    location: '海法，以色列',
    awards: [
      '中以友好优秀学生奖学金（全世界仅12人）',
      'Charney School MSc Fellowship（硕士全奖）',
      'Hatter Distinction scholarship（硕士额外全奖）',
      'Excellent scholarship（系优秀奖学金）',
    ],
  },
  {
    period: '2018.09 — 2022.06',
    school: '三峡大学',
    degree: '学士',
    major: '土木工程',
    grade: '',
    location: '湖北宜昌',
    awards: [
      '一等奖学金',
      '优秀毕业生',
    ],
  },
];
---

<section id="education" class="relative py-24 px-6 bg-tech-dark/50">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold mb-12 text-center">
      <span class="text-tech-blue">//</span> 教育背景
    </h2>

    <div class="space-y-8">
      {education.map((edu, index) => (
        <div
          class="p-6 rounded-lg bg-white/5 backdrop-blur-sm border border-white/10 hover:border-tech-purple/30 transition-colors"
          style={`animation-delay: ${index * 0.2}s`}
        >
          <div class="flex flex-wrap items-start justify-between mb-4">
            <div>
              <h3 class="text-xl font-bold text-white mb-1">{edu.school}</h3>
              <p class="text-tech-purple">{edu.degree} · {edu.major}</p>
            </div>
            <div class="text-right">
              <span class="text-xs font-mono text-tech-cyan">{edu.period}</span>
              {edu.grade && <p class="text-xs text-gray-500 mt-1">{edu.grade}</p>}
            </div>
          </div>

          <div class="flex flex-wrap gap-2 mb-4">
            {edu.awards.map((award) => (
              <span class="px-3 py-1 text-xs rounded-full bg-gradient-to-r from-tech-purple/20 to-tech-blue/20 text-tech-cyan border border-tech-purple/30">
                {award}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 p-6 rounded-lg bg-gradient-to-r from-tech-blue/10 to-tech-purple/10 border border-tech-blue/20">
      <h3 class="text-lg font-bold text-white mb-4">发表成果</h3>
      <div class="space-y-2 text-sm text-gray-400">
        <p>• 累计申请专利 5 项，1 项处于受理中状态</p>
        <p>• 核心论文 1 篇</p>
      </div>
    </div>
  </div>
</section>
