---
const contactInfo = [
  {
    icon: 'email',
    label: '电子邮件',
    value: 'ziruiwww@foxmail.com',
    href: 'mailto:ziruiwww@foxmail.com',
  },
  {
    icon: 'phone',
    label: '电话',
    value: '157-2389-1510',
    href: 'tel:15723891510',
  },
  {
    icon: 'website',
    label: '个人网站',
    value: 'jerryzirui.github.io/Website',
    href: 'https://jerryzirui.github.io/Website',
  },
];
---

<section id="contact" class="relative py-24 px-6 bg-tech-dark/50">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-3xl font-bold mb-4">
      <span class="text-tech-blue">//</span> 联系我
    </h2>
    <p class="text-gray-400 mb-12">欢迎交流与合作</p>

    <div class="grid md:grid-cols-3 gap-6 mb-12">
      {contactInfo.map((item) => (
        <a
          href={item.href}
          target="_blank"
          rel="noopener noreferrer"
          class="p-6 rounded-lg bg-white/5 backdrop-blur-sm border border-white/10 hover:border-tech-blue/50 hover:bg-tech-blue/5 transition-all group"
        >
          <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-tech-blue/10 flex items-center justify-center group-hover:bg-tech-blue/20 transition-colors">
            {item.icon === 'email' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-tech-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            )}
            {item.icon === 'phone' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-tech-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            )}
            {item.icon === 'website' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-tech-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
            )}
          </div>
          <p class="text-xs text-gray-500 mb-1">{item.label}</p>
          <p class="text-sm text-white group-hover:text-tech-blue transition-colors">{item.value}</p>
        </a>
      ))}
    </div>

    <footer class="pt-8 border-t border-white/10">
      <p class="text-sm text-gray-500">
        © 2026 张子睿 · Built with Astro + Three.js
      </p>
    </footer>
  </div>
</section>
